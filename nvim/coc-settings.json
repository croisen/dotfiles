{
    "clangd.path": "/opt/clangd/bin/clangd",

    "coc.preferences.extensionUpdateCheck": "weekly",
    "coc.preferences.silentAutoupdate": true,
    "coc.preferences.formatOnSave": true,

    "rpc.idleText": "Having deep thoughts on why no compile",
    "rpc.useCWDAsFallback": true,

    "prettier.formatterPriority": 1,
    "prettier.bracketSpacing": true,
    "prettier.printWidth": 80,
    "prettier.singleQuote": true,
    "prettier.tabWidth": 4,
    "prettier.trailingComma": "es5",
    "prettier.useTabs": false,

    "Lua.workspace.library": [
        "/usr/share/awesome/lib",
        "/usr/share/nvim/runtime/lua",
        "/usr/share/nvim/runtime/lua/vim",
        "/usr/share/nvim/runtime/lua/vim/lsp"
    ],
    "Lua.diagnostics.globals": [
      "vim"
    ],
    "snippets.ultisnips.pythonPrompt": false
}
